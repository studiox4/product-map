# Hoist all dependencies to the root node_modules (npm-like flat layout).
# The codebase relies on a few phantom deps (packages imported but resolved via
# hoisting rather than declared in the importing package's package.json, e.g.
# @tiptap/core in apps/web, @ai-sdk/provider in apps/api tests). This makes a
# clean `pnpm install --frozen-lockfile` in CI resolve them exactly like local.
shamefully-hoist=true
