{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@/*": ["./src/*"],
      "@productmap/shared": ["../../packages/shared/src/index.ts"],
      "@productmap/shared/*": ["../../packages/shared/src/*"],
      "@productmap/sdk": ["../../packages/sdk/src/index.ts"],
      "@productmap/sdk/*": ["../../packages/sdk/src/*"],
      "@productmap/ui": ["../../packages/ui/src/index.ts"],
      "@productmap/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
