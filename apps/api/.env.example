# --- Required ---

# Postgres/Neon connection string. For Neon, append ?sslmode=require.
DATABASE_URL=postgres://localhost:5432/productmap

# --- Production ---

# Session signing secret. REQUIRED in production (the app fails fast if unset).
# Generate with: openssl rand -hex 32. Changing it invalidates all sessions.
AUTH_SECRET=change-me-openssl-rand-hex-32

# HTTP port (optional, default 3411).
PORT=3411

# Set to 1 so the API serves the built web (apps/web/dist) alongside /api:
# marketing at / and the SPA at /app/*.
SERVE_WEB=1

# Node environment. Set to "production" when self-hosting (enables prod-only
# guards; AUTH_SECRET becomes required).
NODE_ENV=production

# --- Self-hosting ---

# Public base URL of your deployment (used for absolute links + invite emails).
# Default: http://localhost:5173. Set to your real domain in production.
APP_URL=https://your-domain.example

# Trust X-Forwarded-* headers — set to 1 when running behind a proxy / load
# balancer (Railway, nginx, Fly, etc.) so client IPs and secure cookies work.
TRUST_PROXY=1

# Allow anyone to self-register (1) vs invite-only (unset/0). For a public demo
# set 1; for a private workspace leave unset and invite users.
ALLOW_OPEN_SIGNUP=0

# --- Optional: email (Resend, recommended for Railway/serverless hosts) ---
# Resend's HTTPS API works on every hosting plan, unlike raw SMTP (many
# platforms, including Railway's non-Pro plans, block outbound SMTP ports).
# If RESEND_API_KEY is set it takes precedence over SMTP_* below. Leave both
# unset and invites/notifications are link-only (no email sent) — the app
# works fully without either configured.
RESEND_API_KEY=
# Defaults to "ProductMap <no-reply@productmap.local>" if unset. A brand-new
# Resend API key can only send to your own account's email address until you
# verify a sending domain in the Resend dashboard.
RESEND_FROM=

# --- Optional: email (SMTP fallback) ---
# Used only if RESEND_API_KEY (above) is unset. Enables invite / notification
# emails via a traditional SMTP relay. If neither RESEND_API_KEY nor SMTP_HOST
# is set, email is disabled and invites are link-only.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ProductMap <no-reply@your-domain.example>

# --- Optional: AI (Amazon Bedrock) ---
# Setting any of these enables AI drafting; credentials resolve via the
# standard AWS credential chain (profile, env keys, instance role, etc.).

# AWS region for Bedrock (e.g. us-east-1).
AWS_REGION=us-east-1
# Named AWS profile to use from ~/.aws/credentials.
AWS_PROFILE=
# Static access key (alternative to a profile).
AWS_ACCESS_KEY_ID=
# Bedrock model id to draft with (e.g. anthropic.claude-3-5-sonnet-20241022-v2:0).
BEDROCK_MODEL_ID=
